import socket
import threading
import time

target_host = "ip_goes_here"
target_ports = range(start_range, end_range)
batch_size = max(1, len(target_ports) // 20)
start_index = int(task.load_progress())
task.update_total_batch(len(target_ports))


class NmapThread(threading.Thread):
    def __init__(self, port):
        super().__init__()
        self.port = port
        self.daemon = True

    def run(self):
        try:
            if stop_event.is_set():
                return
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(2)
            result = sock.connect_ex((target_host, self.port))
            sock.close()
            if result == 0:
                banner = ""
                try:
                    sock2 = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                    sock2.settimeout(2)
                    sock2.connect((target_host, self.port))
                    sock2.sendall(b"HEAD / HTTP/1.0\r\n\r\n")
                    raw = sock2.recv(256).decode("utf-8", errors="ignore").split("\r\n")[0]
                    banner = raw.strip()
                    sock2.close()
                except Exception:
                    pass
                line = f"{target_host}:{self.port}/tcp  OPEN"
                if banner:
                    line += f"  [{banner[:80]}]"
                with open(f"file_{task.task_id}", "a") as f:
                    f.write(line + "\n")
        except Exception:
            pass
        finally:
            task.release_slot()


for i in range(start_index, len(target_ports), batch_size):
    batch = list(target_ports)[i:i + batch_size]
    for port in batch:
        if stop_event.is_set():
            break
        task.acquire_slot()
        if stop_event.is_set():
            task.release_slot()
            break
        NmapThread(port).start()
    if not stop_event.is_set():
        task.save_progress(i + batch_size)
